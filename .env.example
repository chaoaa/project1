# ====== LLM 配置 (OpenAI 兼容 API) ======
# 支持 DeepSeek / Qwen / OpenAI / Moonshot 等所有 OpenAI 兼容接口
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat

# ====== Embedding 模型 ======
# 默认 BAAI/bge-m3，本地下载失败可换成 BAAI/bge-small-zh-v1.5、shibing624/text2vec-base-chinese 等
EMBEDDING_MODEL=BAAI/bge-m3

# ====== Qdrant 向量数据库 ======
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=school_policy_docs

# ====== Chunk 切分参数 ======
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ====== 检索参数 ======
TOP_K=6

# ====== 拒答阈值 ======
SCORE_THRESHOLD_HIGH=0.75
SCORE_THRESHOLD_MEDIUM=0.45
